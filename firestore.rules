rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in [
          "karthik0612345@gmail.com"
        ];
    }

    function isDelivery() {
      // Add approved delivery partner emails in this list.
      return isSignedIn()
        && request.auth.token.email in [
          "karthik0612345@gmail.com"
        ];
    }

    function isStaff() {
      return isAdmin() || isDelivery();
    }

    function isPhoneCustomer() {
      return isSignedIn()
        && request.auth.token.phone_number is string;
    }

    function isCustomerPhone(phoneNumber) {
      return isPhoneCustomer()
        && phoneNumber is string
        && phoneNumber.matches('^[0-9]{10}$')
        && request.auth.token.phone_number == "+91" + phoneNumber;
    }

    function isOrderCustomer(orderData) {
      return orderData.customerDetails is map
        && isCustomerPhone(orderData.customerDetails.phoneNumber);
    }

    function isSignaturePackageCustomer(packageData) {
      return packageData.phoneNumber is string
        && isCustomerPhone(packageData.phoneNumber);
    }

    function hasValidCustomerDetails(orderData) {
      return orderData.customerDetails is map
        && orderData.customerDetails.keys().hasOnly([
          "name",
          "phoneNumber",
          "deliveryAddress",
          "landmark",
          "googleMapLocation"
        ])
        && orderData.customerDetails.name is string
        && orderData.customerDetails.name.size() >= 2
        && orderData.customerDetails.name.size() <= 80
        && isCustomerPhone(orderData.customerDetails.phoneNumber)
        && orderData.customerDetails.deliveryAddress is string
        && orderData.customerDetails.deliveryAddress.size() >= 8
        && orderData.customerDetails.deliveryAddress.size() <= 500
        && orderData.customerDetails.landmark is string
        && orderData.customerDetails.landmark.size() <= 200
        && orderData.customerDetails.googleMapLocation is string
        && orderData.customerDetails.googleMapLocation.size() <= 500;
    }

    function hasValidNewOrder(orderId) {
      return isPhoneCustomer()
        && request.resource.data.keys().hasOnly([
          "orderId",
          "customerDetails",
          "orderedItems",
          "paymentMethod",
          "subtotal",
          "discount",
          "offer",
          "total",
          "status",
          "paymentStatus",
          "estimatedDeliveryMinutes",
          "deliveryPerson",
          "notificationToken",
          "notificationTokens",
          "statusHistory",
          "orderTimestamp",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.orderId == orderId
        && hasValidCustomerDetails(request.resource.data)
        && request.resource.data.orderedItems is list
        && request.resource.data.orderedItems.size() > 0
        && request.resource.data.orderedItems.size() <= 50
        && request.resource.data.paymentMethod in ["cod", "razorpay"]
        && (
          (
            request.resource.data.paymentMethod == "cod"
            && request.resource.data.paymentStatus == "cash_on_delivery"
          )
          || (
            request.resource.data.paymentMethod == "razorpay"
            && request.resource.data.paymentStatus == "pending"
          )
        )
        && request.resource.data.subtotal is number
        && request.resource.data.subtotal >= 100
        && request.resource.data.subtotal <= 50000
        && request.resource.data.discount is number
        && request.resource.data.discount >= 0
        && request.resource.data.discount <= 100
        && (
          request.resource.data.offer == null
          || (
            request.resource.data.offer is map
            && request.resource.data.offer.keys().hasOnly([
              "code",
              "title",
              "amount"
            ])
            && request.resource.data.offer.code is string
            && request.resource.data.offer.title is string
            && request.resource.data.offer.amount == request.resource.data.discount
          )
        )
        && request.resource.data.total is number
        && request.resource.data.total == request.resource.data.subtotal - request.resource.data.discount
        && request.resource.data.total > 0
        && request.resource.data.total <= 50000
        && request.resource.data.status == "pending"
        && request.resource.data.estimatedDeliveryMinutes == null
        && request.resource.data.deliveryPerson == null
        && request.resource.data.notificationToken == null
        && request.resource.data.notificationTokens is list
        && request.resource.data.notificationTokens.size() == 0
        && request.resource.data.statusHistory is map
        && request.resource.data.statusHistory.keys().hasOnly(["pending"])
        && request.resource.data.statusHistory.pending == request.time
        && request.resource.data.orderTimestamp == request.time
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function isNotificationTokenUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "notificationToken",
        "notificationTokens",
        "updatedAt"
      ]);
    }

    function isSignaturePackageNotificationUpdate() {
      return isSignaturePackageCustomer(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "notificationToken",
          "notificationTokens",
          "lastExpiryNotificationAt",
          "updatedAt"
        ]);
    }

    function isDeliveryCashCollectionUpdate() {
      return isDelivery()
        && resource.data.paymentMethod == "cod"
        && request.resource.data.paymentStatus == "cash_collected"
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "paymentStatus",
          "cashCollectedAt",
          "cashCollectedBy",
          "updatedAt"
        ]);
    }

    function isDeliveryDeliveredUpdate() {
      return isDelivery()
        && request.resource.data.status == "delivered"
        && resource.data.status in ["out_for_delivery", "food_ready"]
        && (
          resource.data.paymentMethod != "cod"
          || resource.data.paymentStatus == "cash_collected"
        )
        && (
          resource.data.paymentMethod != "razorpay"
          || resource.data.paymentStatus in ["paid", "captured"]
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "deliveredAt",
          "deliveredBy",
          "updatedAt",
          "statusHistory"
        ]);
    }

    match /orders/{orderId} {
      allow create: if hasValidNewOrder(orderId) || isAdmin();
      allow get: if isStaff() || isOrderCustomer(resource.data);
      allow list: if isStaff() || isOrderCustomer(resource.data);
      allow update: if isAdmin()
        || ((isStaff() || isOrderCustomer(resource.data)) && isNotificationTokenUpdate())
        || isDeliveryCashCollectionUpdate()
        || isDeliveryDeliveredUpdate();
      allow delete: if isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /signaturePackages/{packageId} {
      allow get: if isAdmin() || isSignaturePackageCustomer(resource.data);
      allow list: if isAdmin() || isSignaturePackageCustomer(resource.data);
      allow create: if isAdmin() || isSignaturePackageCustomer(request.resource.data);
      allow delete: if isAdmin();
      allow update: if isAdmin() || isSignaturePackageNotificationUpdate();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
